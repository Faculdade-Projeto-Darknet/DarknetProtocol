<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark">

    <!-- ===================================================== -->
    <!-- SCROLL -->
    <!-- ===================================================== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- ================================================= -->
            <!-- HEADER -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERFIL DO OPERADOR"
                android:textColor="@color/cyber_green"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:letterSpacing="0.06"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="14"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IDENTIDADE DIGITAL"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_regular"
                android:layout_marginTop="4dp"/>

            <!-- ================================================= -->
            <!-- CARD PERFIL -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_mission_card_dark"
                android:padding="24dp"
                android:layout_marginTop="22dp">

                <FrameLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp">

                    <View
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:background="@drawable/profile_glow_ring"/>

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:layout_gravity="center"
                        android:src="@mipmap/ic_launcher"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/cyber_green"/>

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOQUE PARA ALTERAR"
                    android:textColor="@color/cyber_text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="@font/jetbrains_regular"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:id="@+id/txtNickname"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ghost_404"
                    android:textColor="@color/white"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orbitron_bold"
                    android:layout_marginTop="18dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOQUE NO NOME PARA EDITAR"
                    android:textColor="@color/cyber_text_secondary"
                    android:textSize="10sp"
                    android:fontFamily="@font/jetbrains_regular"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:id="@+id/txtRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RANK • OPERADOR INICIANTE"
                    android:textColor="@color/cyber_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jetbrains_regular"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_tab_inactive"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"/>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- XP -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_mission_card_dark"
                android:padding="20dp"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XP TOTAL"
                        android:textColor="@color/cyber_text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/jetbrains_regular"/>

                    <TextView
                        android:id="@+id/txtXp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="0 XP"
                        android:textColor="@color/cyber_green"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/jetbrains_regular"/>

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressXp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="14dp"
                    android:max="450"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_modern_cyber"/>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- STATS -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_mission_card_dark">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MISSÕES"
                        android:textColor="@color/cyber_text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/jetbrains_regular"/>

                    <TextView
                        android:id="@+id/txtMissions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/4"
                        android:textColor="@color/cyber_green"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/orbitron_bold"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <Space
                    android:layout_width="14dp"
                    android:layout_height="match_parent"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_mission_card_dark">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS"
                        android:textColor="@color/cyber_text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="@font/jetbrains_regular"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ONLINE"
                        android:textColor="@color/cyber_green"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/orbitron_bold"
                        android:layout_marginTop="8dp"
                        android:shadowColor="@color/cyber_green"
                        android:shadowRadius="10"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- CONQUISTAS -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_mission_card_dark"
                android:padding="20dp"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONQUISTAS"
                    android:textColor="@color/cyber_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/orbitron_bold"/>

                <TextView
                    android:id="@+id/txtAchievements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma conquista desbloqueada ainda."
                    android:textColor="@color/cyber_text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="@font/jetbrains_regular"
                    android:layout_marginTop="12dp"/>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- RESET -->
            <!-- ================================================= -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnResetProfile"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:text="RESETAR PROGRESSO"
                android:textColor="#FF6666"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_regular"
                android:background="@drawable/bg_reset_button"/>

        </LinearLayout>

    </ScrollView>

    <!-- ===================================================== -->
    <!-- NAVIGATION -->
    <!-- ===================================================== -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/cyber_bg_terminal"
        app:itemIconTint="@color/cyber_green"
        app:itemTextColor="@color/cyber_green"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>