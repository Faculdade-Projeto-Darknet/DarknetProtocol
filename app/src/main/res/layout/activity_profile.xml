<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERFIL DO OPERADOR"
                android:textColor="@color/cyber_green"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="10"/>

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/imgProfile"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_marginTop="24dp"
                android:src="@mipmap/ic_launcher"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/cyber_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="TOQUE NA FOTO PARA ALTERAR"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/txtNickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Ghost_404"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="TOQUE NO NICK PARA EDITAR"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/txtRank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Rank: Operador Iniciante"
                android:textColor="@color/cyber_green"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="4"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:background="@drawable/bg_cyber_card"
                android:padding="18dp">

                <TextView
                    android:id="@+id/txtXp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XP Total: 0"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="monospace"/>

                <ProgressBar
                    android:id="@+id/progressXp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="450"
                    android:progress="0"
                    android:progressTint="@color/cyber_green"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cyber_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MISSÕES"
                        android:textColor="@color/cyber_text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:id="@+id/txtMissions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="0/4"
                        android:textColor="@color/cyber_green"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"/>

                </LinearLayout>

                <Space
                    android:layout_width="14dp"
                    android:layout_height="match_parent"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_cyber_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS"
                        android:textColor="@color/cyber_text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="ONLINE"
                        android:textColor="@color/cyber_green"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:shadowColor="@color/cyber_green"
                        android:shadowRadius="4"/>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:id="@+id/txtAchievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_cyber_card"
                android:padding="18dp"
                android:text="CONQUISTAS\n\nNenhuma conquista desbloqueada ainda."
                android:textColor="@color/cyber_green"
                android:textSize="14sp"
                android:fontFamily="monospace"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnResetProfile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="24dp"
                android:text="RESETAR PROGRESSO"
                android:textColor="#FF4444"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/bg_cyber_button"
                android:backgroundTint="#251010"/>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/cyber_bg_terminal"
        app:itemIconTint="@color/cyber_green"
        app:itemTextColor="@color/cyber_green"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>