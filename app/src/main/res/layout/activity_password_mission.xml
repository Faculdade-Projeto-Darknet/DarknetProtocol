<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="MISSÃO 02"
            android:textColor="#00FF66"
            android:textSize="15sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="QUEBRA DE SENHA"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Descubra a senha do servidor fictício usando as pistas do terminal."
            android:textColor="#CCCCCC"
            android:textSize="15sp"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtStatusPassword"
            android:text="STATUS: AGUARDANDO TENTATIVA"
            android:textColor="#00FF66"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtStatsPassword"
            android:text="Tentativas: 4 | Dica: Projeto secreto"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtLogPassword"
            android:text="> Arquivo criptografado encontrado.\n> Dica 1: nome do projeto mencionado na missão 1."
            android:textColor="#00FF66"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="#101010"
            android:padding="16dp"
            android:layout_marginTop="22dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edtPassword"
            android:hint="Digite a senha"
            android:hintTextColor="#777777"
            android:textColor="#00FF66"
            android:backgroundTint="#00FF66"
            android:singleLine="true"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnCheckPassword"
            android:text="TESTAR SENHA"
            android:textColor="#00FF66"
            android:backgroundTint="#101010"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnPasswordHint"
            android:text="PEDIR DICA"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnResetPasswordMission"
            android:text="REINICIAR MISSÃO"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

    </LinearLayout>

</ScrollView>