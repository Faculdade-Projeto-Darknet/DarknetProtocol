<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="MISSÃO 02"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="QUEBRA DE SENHA"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Use o teclado do sistema para montar a senha correta."
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtStatusPassword"
            android:text="STATUS: AGUARDANDO TENTATIVA"
            android:textColor="@color/cyber_green"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="4"/>

        <TextView
            android:id="@+id/txtStatsPassword"
            android:text="Tentativas: 4 | Dicas usadas: 0 | XP: até +250"
            android:textColor="@color/cyber_text_secondary"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtLogPassword"
            android:text="&gt; Arquivo criptografado encontrado.\n&gt; Dica 1: nome do projeto mencionado na missão 1."
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_card"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="64dp"/>

        <TextView
            android:id="@+id/txtPasswordDisplay"
            android:text="_ _ _ _ _"
            android:textColor="@color/cyber_green"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:background="@drawable/bg_cyber_card"
            android:padding="16dp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="6"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginTop="20dp">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyO" android:text="O" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyR" android:text="R" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyI" android:text="I" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyN" android:text="N" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyA" android:text="A" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyB" android:text="B" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyC" android:text="C" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyX" android:text="X" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btnKeyZ" android:text="Z" android:textColor="@color/cyber_green" android:fontFamily="monospace" android:background="@drawable/bg_cyber_button" android:layout_width="0dp" android:layout_height="48dp" android:layout_columnWeight="1" android:layout_margin="3dp"/>

        </GridLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDeleteKey"
            android:text="APAGAR"
            android:textColor="#FF4444"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:backgroundTint="#251010"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="13sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCheckPassword"
            android:text="TESTAR SENHA"
            android:textColor="@color/cyber_green"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="13sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPasswordHint"
            android:text="PEDIR DICA"
            android:textColor="@color/white"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"
            android:backgroundTint="#151515"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="13sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnResetPasswordMission"
            android:text="REINICIAR MISSÃO"
            android:textColor="@color/cyber_text_secondary"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"
            android:backgroundTint="#151515"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:textSize="13sp"/>

    </LinearLayout>

</ScrollView>