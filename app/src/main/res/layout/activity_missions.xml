<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cyber_overlay">

    <!-- ===================================================== -->
    <!-- CONTEÚDO -->
    <!-- ===================================================== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNavigation"
        android:clipToPadding="false"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ================================================= -->
            <!-- HEADER -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MAPA DE MISSÕES"
                android:textColor="@color/cyber_green"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="12"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PROJETO ORION • CAMPANHA ATIVA"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_regular"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:layout_marginBottom="22dp"/>

            <!-- ================================================= -->
            <!-- ABAS -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tabs_container"
                android:padding="5dp"
                android:layout_marginBottom="24dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnAvailable"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="DISPONÍVEIS"
                    android:textColor="@color/cyber_bg_dark"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:fontFamily="@font/jetbrains_regular"
                    android:background="@drawable/bg_tab_active"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="match_parent"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCompleted"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="CONCLUÍDAS"
                    android:textColor="@color/cyber_green"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:fontFamily="@font/jetbrains_regular"
                    android:background="@drawable/bg_tab_inactive"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:padding="0dp"/>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- MISSÕES DISPONÍVEIS -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutAvailableMissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- MISSÃO 01 -->

                <include layout="@layout/item_mission_1"/>

                <!-- MISSÃO 02 -->

                <include layout="@layout/item_mission_2"/>

                <!-- MISSÃO 03 -->

                <include layout="@layout/item_mission_3"/>

                <!-- MISSÃO 04 -->

                <include layout="@layout/item_mission_4"/>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- MISSÕES CONCLUÍDAS -->
            <!-- ================================================= -->

            <LinearLayout
                android:id="@+id/layoutCompletedMissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtCompletedList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="&gt; Nenhuma missão concluída."
                    android:textColor="@color/cyber_green"
                    android:textSize="14sp"
                    android:fontFamily="@font/jetbrains_regular"
                    android:background="@drawable/bg_mission_card_dark"
                    android:padding="18dp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- ===================================================== -->
    <!-- NAVEGAÇÃO -->
    <!-- ===================================================== -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/cyber_bg_terminal"
        app:itemIconTint="@color/cyber_green"
        app:itemTextColor="@color/cyber_green"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>