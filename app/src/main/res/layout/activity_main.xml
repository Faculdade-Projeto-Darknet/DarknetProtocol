<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_darknet"
        android:scaleType="centerCrop"
        android:alpha="0.25"/>

    <LinearLayout
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_cyber_card"
        android:padding="26dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DARKNET"
            android:textColor="@color/cyber_green"
            android:textSize="38sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:shadowColor="@color/cyber_green"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="15" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTOCOL"
            android:textColor="@color/cyber_green"
            android:textSize="19sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.35"
            android:shadowColor="@color/cyber_green"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10" />

        <TextView
            android:id="@+id/txtCursor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="42dp"
            android:gravity="center"
            android:text="&gt;_"
            android:textColor="@color/cyber_green"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:shadowColor="@color/cyber_green"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="12"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONECTE-SE AO SISTEMA"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginTop="34dp"
            android:letterSpacing="0.05"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="240dp"
            android:layout_height="16dp"
            android:progress="0"
            android:max="100"
            android:visibility="invisible"
            android:progressDrawable="@drawable/progress_neon"
            android:layout_marginTop="14dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStart"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="INICIAR"
            android:textColor="@color/cyber_green"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="18dp"
            android:letterSpacing="0.1"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:padding="0dp"/>

        <com.google.android.gms.common.SignInButton
        android:id="@+id/btnGoogleLogin"
        android:layout_width="220dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textColor="@color/cyber_text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

</FrameLayout>