<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_darknet"
        android:scaleType="centerCrop"
        android:alpha="0.45"/>

    <LinearLayout
        android:layout_width="340dp"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/card_border"
        android:padding="26dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DARKNET"
            android:textColor="#00FF66"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTOCOL"
            android:textColor="#00FF66"
            android:textSize="19sp"
            android:textStyle="bold"
            android:letterSpacing="0.35"/>

        <TextView
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_marginTop="42dp"
            android:gravity="center"
            android:text="&gt;_"
            android:textColor="#00FF66"
            android:textSize="42sp"
            android:textStyle="bold"
            android:background="#44101010"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONECTE-SE AO SISTEMA"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="34dp"/>

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="240dp"
            android:layout_height="16dp"
            android:progress="0"
            android:max="100"
            android:visibility="invisible"
            android:progressDrawable="@drawable/progress_neon"
            android:layout_marginTop="14dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="INICIAR"
            android:textColor="#00FF66"
            android:textStyle="bold"
            android:backgroundTint="#101010"
            android:layout_marginTop="18dp"/>

        <TextView
            android:layout_width="220dp"
            android:layout_height="48dp"
            android:text="FAZER LOGIN"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="#33101010"
            android:layout_marginTop="10dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

</FrameLayout>