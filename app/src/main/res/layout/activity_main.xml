<?xml version="1.0" encoding="utf-8"?>

<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_darknet"
        android:scaleType="centerCrop"
        android:alpha="0.28"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DARKNET"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:letterSpacing="0.12"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="12"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROTOCOL"
            android:textColor="@color/cyber_green"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:letterSpacing="0.28"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENTRE. HACK. SOBREVIVA."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/jetbrains_regular"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.08"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_cyber_card"
            android:padding="22dp"
            android:layout_marginTop="42dp">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CONECTE-SE AO SISTEMA"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/jetbrains_regular"
                android:gravity="center"/>

            <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="18dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/progress_modern_cyber"
            android:indeterminate="false"
            android:visibility="gone"/>

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:text="CONTINUAR COMO CONVIDADO"
                android:textColor="@color/cyber_bg_dark"
                android:textStyle="bold"
                android:textSize="14sp"
                android:fontFamily="@font/jetbrains_regular"
                android:backgroundTint="@color/cyber_green"
                android:minHeight="0dp"
                android:minWidth="0dp"/>

            <com.google.android.gms.common.SignInButton
                android:id="@+id/btnGoogleLogin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MISSÕES"
                android:textColor="@color/cyber_green"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_regular"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HACKING"
                android:textColor="@color/cyber_green"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_regular"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PROGRESSO"
                android:textColor="@color/cyber_green"
                android:textSize="10sp"
                android:fontFamily="@font/jetbrains_regular"
                android:gravity="center"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>