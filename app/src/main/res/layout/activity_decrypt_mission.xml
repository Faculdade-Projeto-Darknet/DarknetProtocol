<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <!-- HEADER -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MISSÃO • 03"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:letterSpacing="0.12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ARQUIVO FANTASMA"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="8dp"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analise o arquivo criptografado e recupere a palavra original usando a cifra indicada."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

        <!-- STATUS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="18dp"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/txtDecryptStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STATUS: ARQUIVO CRIPTOGRAFADO"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="6"/>

            <TextView
                android:id="@+id/txtDecryptStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tentativas: 3 • XP: +300"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/jetbrains_regular"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- TERMINAL -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="18dp"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARQUIVO ENCONTRADO"
                android:textColor="@color/cyber_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"/>

            <TextView
                android:id="@+id/txtDecryptLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:text="&gt; Arquivo encontrado: ghost_file.enc\n&gt; Conteúdo criptografado: RULRQ\n&gt; Dica: Cifra de César -3"
                android:textColor="@color/cyber_green"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

        <!-- RESPOSTA -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESPOSTA"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.08"/>

        <EditText
            android:id="@+id/edtDecryptAnswer"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:hint="Digite a palavra descriptografada"
            android:textColor="@color/cyber_green"
            android:textColorHint="@color/cyber_text_secondary"
            android:textSize="15sp"
            android:fontFamily="@font/jetbrains_regular"
            android:singleLine="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_mission_card_dark"/>

        <!-- AÇÕES -->

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCheckDecrypt"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="VALIDAR ARQUIVO"
            android:textColor="@color/cyber_bg_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:backgroundTint="@color/cyber_green"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDecryptHint"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="PEDIR DICA"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_cyber_button"
            android:backgroundTint="#181818"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnResetDecrypt"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:text="REINICIAR MISSÃO"
            android:textColor="@color/cyber_text_secondary"
            android:textSize="13sp"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_cyber_button"
            android:backgroundTint="#151515"/>

    </LinearLayout>

</ScrollView>