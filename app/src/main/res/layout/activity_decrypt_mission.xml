<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="MISSÃO 03"
            android:textColor="#00FF66"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="ARQUIVO FANTASMA"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtDecryptStatus"
            android:text="STATUS: ARQUIVO CRIPTOGRAFADO"
            android:textColor="#00FF66"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtDecryptStats"
            android:text="Tentativas: 3 | XP: até +300"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtDecryptLog"
            android:text="> Arquivo encontrado: ghost_file.enc\n> Conteúdo criptografado: RULRQ\n> Dica: Cifra de César -3"
            android:textColor="#00FF66"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:background="#101010"
            android:padding="18dp"
            android:layout_marginTop="22dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edtDecryptAnswer"
            android:hint="Digite a palavra descriptografada"
            android:textColor="#00FF66"
            android:backgroundTint="#00FF66"
            android:singleLine="true"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnCheckDecrypt"
            android:text="VALIDAR ARQUIVO"
            android:textColor="#00FF66"
            android:backgroundTint="#101010"
            android:layout_marginTop="18dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnDecryptHint"
            android:text="PEDIR DICA"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnResetDecrypt"
            android:text="REINICIAR MISSÃO"
            android:textColor="#FFFFFF"
            android:backgroundTint="#333333"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

    </LinearLayout>

</ScrollView>