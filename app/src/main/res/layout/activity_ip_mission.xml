<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="28dp">

        <!-- HEADER -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MISSÃO • 04"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:letterSpacing="0.12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NÓ INVASOR"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="8dp"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analise os registros de acesso e identifique qual IP não pertence à rede local da HexaCryp."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

        <!-- STATUS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="18dp"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/txtIpStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STATUS: ANALISANDO LOGS"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="6"/>

            <TextView
                android:id="@+id/txtIpStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tentativas: 3 • Detecção: 0% • XP: +350"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/jetbrains_regular"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- TERMINAL -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="18dp"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOG DE ACESSO"
                android:textColor="@color/cyber_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"/>

            <TextView
                android:id="@+id/txtIpLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:text="&gt; Conexão suspeita detectada.\n&gt; Origem fora da rede local.\n&gt; Escolha o IP invasor."
                android:textColor="@color/cyber_green"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

        <!-- ESCOLHAS -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IPS DETECTADOS"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="24dp"
            android:letterSpacing="0.08"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp1"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:text="192.168.0.12"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp2"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="10.0.0.45"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp3"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="172.16.4.91"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp4"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="185.221.77.13"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"/>

        <!-- RESET -->

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnResetIpMission"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:text="REINICIAR MISSÃO"
            android:textColor="#FF6666"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_reset_button"/>

    </LinearLayout>

</ScrollView>