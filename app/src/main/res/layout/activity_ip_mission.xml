<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="MISSÃO 04"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="NÓ INVASOR"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtIpStatus"
            android:text="STATUS: ANALISANDO LOGS"
            android:textColor="@color/cyber_green"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textSize="15sp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="4"/>

        <TextView
            android:id="@+id/txtIpStats"
            android:text="Tentativas: 3 | Detecção: 0% | XP: até +350"
            android:textColor="@color/cyber_text_secondary"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/txtIpLog"
            android:text="&gt; Conexão suspeita detectada.\n&gt; Origem fora da rede local.\n&gt; Escolha o IP invasor."
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_card"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="70dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp1"
            android:text="192.168.0.12"
            android:textColor="@color/cyber_green"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="14sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp2"
            android:text="10.0.0.45"
            android:textColor="@color/cyber_green"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="14sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp3"
            android:text="172.16.4.91"
            android:textColor="@color/cyber_green"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="14sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnIp4"
            android:text="185.221.77.13"
            android:textColor="@color/cyber_green"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="14sp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnResetIpMission"
            android:text="REINICIAR MISSÃO"
            android:textColor="#FF4444"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_cyber_button"
            android:backgroundTint="#251010"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:textSize="13sp"/>

    </LinearLayout>

</ScrollView>