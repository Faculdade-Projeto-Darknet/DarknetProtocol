<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="26dp">

        <!-- HEADER -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MISSÃO • 01"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:letterSpacing="0.12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INVASÃO À REDE"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="8dp"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Objetivo: acessar o servidor fictício da HexaCryp e extrair os arquivos do Projeto Orion."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

        <!-- STATUS CARD -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="18dp"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STATUS: AGUARDANDO COMANDO"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="6"/>

            <TextView
                android:id="@+id/txtStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tentativas: 3 • Detecção: 0% • XP: +150"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/jetbrains_regular"
                android:layout_marginTop="8dp"/>

            <ProgressBar
                android:id="@+id/progressMission"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="16dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_modern_cyber"/>

        </LinearLayout>

        <!-- TERMINAL -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="18dp"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERMINAL"
                android:textColor="@color/cyber_green"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"/>

            <TextView
                android:id="@+id/txtLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:text="&gt; Sistema pronto.\n&gt; Descubra a sequência correta de infiltração."
                android:textColor="@color/cyber_green"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

        <!-- COMANDOS -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMANDOS DISPONÍVEIS"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.08"/>

        <!-- BOTÕES -->

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:text="SCAN REDE"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_cyber_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnProxy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="ATIVAR PROXY"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_cyber_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBypass"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="BYPASS FIREWALL"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_cyber_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnExtract"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:text="EXTRAIR DADOS"
            android:textColor="@color/cyber_bg_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:backgroundTint="@color/cyber_green"/>

        <!-- RESET -->

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:text="REINICIAR TENTATIVA"
            android:textColor="#FF6666"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_reset_button"/>

    </LinearLayout>

</ScrollView>