<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_briefing"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BRIEFING • MISSÃO 04"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:letterSpacing="0.12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NÓ INVASOR"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="10dp"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Após descriptografar os arquivos do Projeto Orion, um acesso suspeito foi detectado nos logs da HexaCryp. Sua missão é identificar qual endereço IP está fora da rede local."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="5dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="20dp"
            android:layout_marginTop="26dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBJETIVO"
                android:textColor="@color/cyber_green"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analise os IPs disponíveis e escolha o endereço suspeito."
                android:textColor="@color/cyber_text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/jetbrains_regular"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="REDES LOCAIS:\n192.168.x.x\n10.x.x.x\n172.16.x.x"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/bg_cyber_button"
                android:padding="18dp"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="6dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:text="XP\n+350"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@drawable/bg_mission_card_dark"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:text="TENTATIVAS\n03"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@drawable/bg_mission_card_dark"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:text="NÍVEL\nMÉDIO"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@drawable/bg_mission_card_dark"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AVISO ÉTICO: esta missão ensina leitura básica de endereços IP em um ambiente fictício. Nada aqui rastreia pessoas reais. Porque transformar aula de rede em perseguição digital seria o tipo de ideia que faz professor perder fé na turma."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartMission4"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="INICIAR MISSÃO"
            android:textColor="@color/cyber_bg_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:backgroundTint="@color/cyber_green"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

    </LinearLayout>

</ScrollView>