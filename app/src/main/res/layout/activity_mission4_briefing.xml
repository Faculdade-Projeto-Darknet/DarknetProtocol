<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="BRIEFING - MISSÃO 04"
            android:textColor="@color/cyber_green"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="NÓ INVASOR"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="8"/>

        <TextView
            android:text="Após descriptografar os arquivos do Projeto Orion, um acesso suspeito foi detectado nos logs da HexaCryp. Sua missão é identificar qual IP está fora da rede local."
            android:textColor="@color/white"
            android:textSize="15sp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:text="OBJETIVO"
            android:textColor="@color/cyber_green"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Analise os IPs disponíveis e escolha o endereço suspeito.\n\nDica: redes locais geralmente começam com 192.168, 10. ou 172.16."
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_card"
            android:padding="18dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="RECOMPENSA: até 350 XP\nTENTATIVAS: 3\nDIFICULDADE: Média"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_card"
            android:padding="18dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartMission4"
            android:text="INICIAR MISSÃO"
            android:textColor="@color/cyber_green"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="32dp"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:textSize="14sp"
            android:letterSpacing="0.05"/>

    </LinearLayout>

</ScrollView>