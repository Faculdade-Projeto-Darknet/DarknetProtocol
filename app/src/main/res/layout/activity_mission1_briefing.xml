<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="BRIEFING - MISSÃO 01"
            android:textColor="#00FF66"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="INVASÃO À REDE"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="A corporação fictícia HexaCryp esconde arquivos relacionados ao Projeto Orion. Sua tarefa é executar uma sequência correta de infiltração simulada para acessar os dados."
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="OBJETIVO"
            android:textColor="#00FF66"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Execute os comandos na ordem correta:\n\nSCAN → PROXY → BYPASS → EXTRACT"
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:background="#101010"
            android:padding="18dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="RECOMPENSA: até 200 XP\nRISCO: Detecção aumenta ao errar\nDIFICULDADE: Fácil"
            android:textColor="#00FF66"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:background="#101010"
            android:padding="18dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnStartMission1"
            android:text="INICIAR MISSÃO"
            android:textColor="#00FF66"
            android:backgroundTint="#101010"
            android:layout_marginTop="32dp"
            android:layout_width="match_parent"
            android:layout_height="58dp"/>

    </LinearLayout>

</ScrollView>