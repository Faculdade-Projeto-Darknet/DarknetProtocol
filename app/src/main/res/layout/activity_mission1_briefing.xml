<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="BRIEFING - MISSÃO 01"
            android:textColor="@color/cyber_green"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="INVASÃO À REDE"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="8"/>

        <TextView
            android:text="A corporação fictícia HexaCryp esconde arquivos relacionados ao Projeto Orion. Sua tarefa é executar uma sequência correta de infiltração simulada para acessar os dados."
            android:textColor="@color/white"
            android:textSize="15sp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.2"/>

        <TextView
            android:text="OBJETIVO"
            android:textColor="@color/cyber_green"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginTop="28dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Execute os comandos na ordem correta:\n\nSCAN → PROXY → BYPASS → EXTRACT"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_card"
            android:padding="18dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="RECOMPENSA: até 200 XP\nRISCO: Detecção aumenta ao errar\nDIFICULDADE: Fácil"
            android:textColor="@color/cyber_green"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_card"
            android:padding="18dp"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartMission1"
            android:text="INICIAR MISSÃO"
            android:textColor="@color/cyber_green"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:background="@drawable/bg_cyber_button"
            android:layout_marginTop="32dp"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:textSize="14sp"
            android:letterSpacing="0.05"/>

    </LinearLayout>

</ScrollView>