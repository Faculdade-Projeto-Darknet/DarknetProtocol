<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark"
    android:clipToPadding="false"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- HEADER -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BRIEFING • MISSÃO 03"
            android:textColor="@color/cyber_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="@font/jetbrains_regular"
            android:letterSpacing="0.12"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ARQUIVO FANTASMA"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:fontFamily="@font/orbitron_bold"
            android:layout_marginTop="10dp"
            android:shadowColor="@color/cyber_green"
            android:shadowRadius="12"/>

        <!-- DESCRIÇÃO -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Após acessar partes do Projeto Orion, você encontrou um arquivo criptografado chamado ghost_file.enc. O conteúdo foi protegido utilizando uma cifra clássica de deslocamento."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="5dp"/>

        <!-- OBJETIVO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="20dp"
            android:layout_marginTop="26dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OBJETIVO"
                android:textColor="@color/cyber_green"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Descriptografe o conteúdo do arquivo utilizando a pista fornecida."
                android:textColor="@color/cyber_text_secondary"
                android:textSize="13sp"
                android:fontFamily="@font/jetbrains_regular"
                android:layout_marginTop="12dp"/>

            <!-- BLOCO TERMINAL -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ghost_file.enc\n\nCONTEÚDO:\nRULRQ\n\nCIFRA:\nCÉSAR -3"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:background="@drawable/bg_cyber_button"
                android:padding="18dp"
                android:layout_marginTop="16dp"
                android:lineSpacingExtra="6dp"/>

        </LinearLayout>

        <!-- STATS -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:text="XP\n+300"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@drawable/bg_mission_card_dark"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:text="TENTATIVAS\n03"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@drawable/bg_mission_card_dark"/>

            <Space
                android:layout_width="12dp"
                android:layout_height="match_parent"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="86dp"
                android:layout_weight="1"
                android:text="NÍVEL\nMÉDIO"
                android:textColor="@color/cyber_green"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:gravity="center"
                android:background="@drawable/bg_mission_card_dark"/>

        </LinearLayout>

        <!-- AVISO -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AVISO ÉTICO: esta missão utiliza apenas conceitos históricos e educativos de criptografia. Nenhum dado real está sendo protegido aqui. Felizmente, porque deixar informação séria usando César em 2026 seria praticamente pedir demissão da segurança digital."
            android:textColor="@color/cyber_text_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/jetbrains_regular"
            android:background="@drawable/bg_mission_card_dark"
            android:padding="16dp"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"/>

        <!-- BOTÃO -->

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnStartMission3"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:text="INICIAR MISSÃO"
            android:textColor="@color/cyber_bg_dark"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="@font/jetbrains_regular"
            android:backgroundTint="@color/cyber_green"
            android:minHeight="0dp"
            android:minWidth="0dp"/>

    </LinearLayout>

</ScrollView>