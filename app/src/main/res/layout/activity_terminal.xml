<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg_dark">

    <!-- ===================================================== -->
    <!-- SCROLL -->
    <!-- ===================================================== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- ================================================= -->
            <!-- HEADER -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERMINAL_ÉTICO"
                android:textColor="@color/cyber_green"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="@font/orbitron_bold"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="10"/>

            <!-- ================================================= -->
            <!-- TERMINAL -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/txtTerminal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="240dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_cyber_card"
                android:fontFamily="monospace"
                android:padding="18dp"
                android:text="&gt; Terminal iniciado.\n&gt; Digite HELP."
                android:textColor="@color/cyber_green"
                android:textSize="13sp"
                android:maxLines="999"
                android:scrollbars="vertical"/>

            <!-- ================================================= -->
            <!-- DISPLAY -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/txtCommandDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_cyber_card"
                android:fontFamily="monospace"
                android:padding="16dp"
                android:text="&gt;"
                android:textColor="@color/cyber_green"
                android:textSize="18sp"
                android:textStyle="bold"
                android:shadowColor="@color/cyber_green"
                android:shadowRadius="4"/>

            <!-- ================================================= -->
            <!-- TECLADO -->
            <!-- ================================================= -->

            <include layout="@layout/keyboard_row_1"/>
            <include layout="@layout/keyboard_row_2"/>
            <include layout="@layout/keyboard_row_3"/>

            <!-- ================================================= -->
            <!-- CONTROLES -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnDelete"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="APAGAR"
                    android:textColor="#FF4444"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_cyber_button"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnSpace"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.8"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="ESPAÇO"
                    android:textColor="@color/cyber_green"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_cyber_button"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

                <Button
                    android:id="@+id/btnExecute"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.2"
                    android:layout_marginStart="6dp"
                    android:text="EXECUTAR"
                    android:textColor="@color/cyber_bg_dark"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:backgroundTint="@color/cyber_green"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>

            </LinearLayout>

            <!-- ================================================= -->
            <!-- CLEAR -->
            <!-- ================================================= -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnClearTerminal"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="LIMPAR HISTÓRICO"
                android:textColor="@color/cyber_text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:background="@drawable/bg_cyber_button"/>

        </LinearLayout>

    </ScrollView>

    <!-- ===================================================== -->
    <!-- NAVIGATION -->
    <!-- ===================================================== -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/cyber_bg_terminal"
        app:itemIconTint="@color/cyber_green"
        app:itemTextColor="@color/cyber_green"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>