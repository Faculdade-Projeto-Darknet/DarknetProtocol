<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:text="BRIEFING - MISSÃO 02"
            android:textColor="#00FF66"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="QUEBRA DE SENHA"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Após recuperar arquivos do Projeto Orion, você encontrou um cofre digital protegido por senha. Use as pistas do terminal para descobrir a palavra correta."
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="OBJETIVO"
            android:textColor="#00FF66"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Descubra a senha usando o teclado próprio do jogo.\n\nDica inicial: a senha está ligada ao Projeto Orion."
            android:textColor="#CCCCCC"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:background="#101010"
            android:padding="18dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="RECOMPENSA: até 250 XP\nTENTATIVAS: 4\nDIFICULDADE: Média"
            android:textColor="#00FF66"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:background="#101010"
            android:padding="18dp"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnStartMission2"
            android:text="INICIAR MISSÃO"
            android:textColor="#00FF66"
            android:backgroundTint="#101010"
            android:layout_marginTop="32dp"
            android:layout_width="match_parent"
            android:layout_height="58dp"/>

    </LinearLayout>

</ScrollView>